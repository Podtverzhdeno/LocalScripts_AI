# ============================================================
#  LocalScript — environment configuration
#  This is the ONLY file you need to edit.
# ============================================================

# ── Default LLM (used by all agents unless overridden below) ──
#
# Uncomment ONE block:

# Option 1: Ollama — local, free, no API key
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# Option 2: OpenRouter — cheap, many models
# LLM_BACKEND=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-v1-...

# Option 3: OpenAI directly
# LLM_BACKEND=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Option 4: Anthropic (Claude)
# LLM_BACKEND=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# ── Per-agent overrides (optional) ───────────────────────────
# Mix local + cloud: e.g. generate locally, review via cloud.
# If not set, each agent uses the default LLM above.

# GENERATOR_BACKEND=ollama
# GENERATOR_MODEL=qwen2.5-coder:7b

# VALIDATOR_BACKEND=ollama
# VALIDATOR_MODEL=qwen2.5-coder:7b

# REVIEWER_BACKEND=openrouter
# REVIEWER_MODEL=openai/gpt-4o-mini

# ── Pipeline settings ────────────────────────────────────────
# MAX_ITERATIONS=3
# EXECUTION_TIMEOUT=10
