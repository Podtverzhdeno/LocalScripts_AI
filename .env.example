# ============================================================
#  LocalScript — environment configuration
#  This is the ONLY file you need to edit.
# ============================================================

# ── Default LLM (used by all agents unless overridden below) ──
#
# Uncomment ONE block:

# Option 1: Ollama — local, free, no API key
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=45
# Note: 7B/8B models auto-use simplified prompts (60% shorter, 2.5x faster)
# Timeout reduced to 45s (was 60s) - prevents hanging while allowing completion

# Option 2: OpenRouter — cheap, many models
# LLM_BACKEND=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-v1-...

# Option 3: OpenAI directly
# LLM_BACKEND=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Option 4: Anthropic (Claude)
# LLM_BACKEND=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# ── Per-agent overrides (optional) ───────────────────────────
# Mix local + cloud: e.g. generate locally, review via cloud.
# If not set, each agent uses the default LLM above.

# GENERATOR_BACKEND=ollama
# GENERATOR_MODEL=qwen2.5-coder:7b

# VALIDATOR_BACKEND=ollama
# VALIDATOR_MODEL=qwen2.5-coder:7b

# REVIEWER_BACKEND=openrouter
# REVIEWER_MODEL=openai/gpt-4o-mini

# ── Small model optimization (optional) ──────────────────────
# Auto-enabled for models with 7b/8b/3b in name.
# Force enable for any model:
# USE_SMALL_PROMPTS=true

# ── Reasoning strategies (optional) ──────────────────────────
# Enhance code quality via multi-step reasoning (adds LLM calls).
# Options: none (default), reflect (3 calls), cot (2 calls)
# Recommended: none for 7B models, reflect for 30B+ models
# GENERATOR_STRATEGY=none

# ── Clarifier (optional) ─────────────────────────────────────
# Enable task clarification questions for ambiguous tasks
# Disable for faster generation (saves 30-60 seconds)
# Recommended: false for 7B models (minimal benefit, adds latency)
# CLARIFIER_ENABLED=false

# ── RAG (Retrieval-Augmented Generation) ─────────────────────
# Enable/disable RAG workflow (Retriever + Approver agents)
# Set to false if you experience hanging or want faster generation
# RAG_ENABLED=true
# RAG_USE_NEW_WORKFLOW=true

# Performance optimization: cache RAG results for similar tasks
# Saves 90-180 seconds on repeated queries (recommended for 7B models)
# RAG_CACHE_ENABLED=true
# RAG_CACHE_MAX_SIZE=100

# Advanced: skip Approver evaluation (use all retrieved examples)
# Only use if Approver is too slow or hanging (not recommended - may reduce quality)
# RAG_SKIP_APPROVAL=false

# ── Pipeline settings ────────────────────────────────────────
# MAX_ITERATIONS=3
# EXECUTION_TIMEOUT=10

# Test pass threshold (0.0-1.0): minimum ratio of passing tests to accept code
# Default: 0.5 (50% of tests must pass)
# Set lower if Test Generator creates incorrect tests for 7B models
# TEST_PASS_THRESHOLD=0.5
